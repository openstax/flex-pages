{
  "name": "@project/root",
  "version": "1.0.0",
  "devDependencies": {
    "cspell": "^5.18.5",
    "syncpack": "^15.3.1"
  },
  "private": true,
  "scripts": {
    "build": "./scripts/build.bash",
    "ci": "CI=true npm-run-all ci:*",
    "ci:packages": "./scripts/ci.bash",
    "ci:spelling": "cspell -c ./cspell.json --gitignore -e 'packages/**' '**'",
    "ci:versions": "syncpack lint",
    "preinstall": "npx only-allow npm"
  },
  "workspaces": [
    "packages/*"
  ]
}
