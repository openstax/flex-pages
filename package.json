{
  "name": "@openstax/flex-page-renderer",
  "version": "1.1.6",
  "sideEffects": [
    "**/*.css"
  ],
  "dependencies": {
    "classnames": "^2.5.1",
    "color": "^5.0.0",
    "isomorphic-dompurify": "^2.36.0",
    "jsdom": "^28.1.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25",
    "@rollup/plugin-node-resolve": "^15",
    "@rollup/plugin-replace": "^5",
    "@rollup/plugin-terser": "^0.4",
    "@types/jsdom": "^28.0.3",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^5.13.0",
    "@typescript-eslint/parser": "^5.13.0",
    "cspell": "^5.18.5",
    "eslint": "^8.10.0",
    "eslint-plugin-import": "^2.25.4",
    "npm-run-all": "^4.1.5",
    "pattern-library": "openstax/pattern-library#semver:^1.5.0",
    "postcss": "^8",
    "rollup": "^4",
    "rollup-plugin-postcss": "^4",
    "sass": "^1.86.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "exports": {
    ".": {
      "browser": "./dist/esm/index.js",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./*": {
      "browser": "./dist/esm/*.js",
      "import": "./dist/esm/*.js",
      "require": "./dist/cjs/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "types": "index.d.ts",
  "unpkg": "dist/umd/flex-page-renderer.js",
  "jsdelivr": "dist/umd/flex-page-renderer.js",
  "typesVersions": {
    "*": {
      "*": [
        "dist/esm/*",
        "dist/esm/*.d.ts",
        "dist/esm/*/index.d.ts"
      ]
    }
  },
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "build": "./script/build.bash",
    "build:clean": "yarn clean && yarn build",
    "ci": "CI=true npm-run-all ci:*",
    "ci:lint": "eslint --max-warnings=0 .",
    "ci:spelling": "git ls-files | yarn cspell -c ../../cspell.json --file-list stdin",
    "ci:typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  }
}
