            "id": "c8a3f1e2-1111-0000-0000-000000000019"
          },
          {
            "type": "faq",
            "value": {
              "items": [
                {
                  "question": "Can I customize a textbook?",
                  "id": "customize",
                  "answer": "<p data-block-key=\"b1\">Absolutely. OpenStax books are openly licensed, so you can remix, reorder, and adapt the content to match your syllabus.</p>"
                },
                {
                  "question": "What formats are available?",
                  "id": "formats",
                  "answer": "<p data-block-key=\"b2\">Read online, download a PDF, use the web view on any device, or order an affordable print copy.</p>"
                },
                {
                  "question": "How is OpenStax funded?",
                  "id": "funding",
                  "answer": "<p data-block-key=\"b3\">OpenStax is supported by philanthropic foundations and our community of supporters, which is what lets us keep our textbooks free for students.</p>"
                }
              ],
              "config": [
                {
