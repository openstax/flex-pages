                }
              ]
            },
            "id": "c8a3f1e2-1111-0000-0000-000000000019"
          },
          {
            "type": "faq",
            "value": {
              "items": [
                {
                  "question": "Can I change how a block looks?",
                  "id": "customize",
                  "answer": "<p data-block-key=\"b1\">Absolutely. Most blocks have config options for things like color, padding, and alignment, so you can adapt them to your layout.</p>"
                },
                {
                  "question": "What happens on smaller screens?",
                  "id": "responsive",
                  "answer": "<p data-block-key=\"b2\">Blocks are responsive. Columns stack, cards collapse to one column, and content reflows to fit phones and tablets.</p>"
                },
                {
                  "question": "Can one answer stay open while I read another?",
                  "id": "allow-multiple",
                  "answer": "<p data-block-key=\"b3\">Yes. This FAQ has allow_multiple turned on, so opening one question leaves the others open too.</p>"
                }
              ],
              "config": [
                {
                  "type": "allow_multiple",
                  "value": "true",
                  "id": "c8a3f1e2-2222-0000-0000-000000000010"
                },
