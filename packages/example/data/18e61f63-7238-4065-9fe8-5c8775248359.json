                    {
                      "type": "hero",
                      "value": {
                        "content": [
                          {
                            "type": "text",
                            "value": "<h3 data-block-key=\"a01\">A hero inside a tab</h3><p data-block-key=\"a02\">This panel holds a hero block. Tabs can contain structural blocks like heroes, sections, and columns, so each panel gets full layout control.</p>",
                            "id": "b1b2c3d4-3333-2222-1111-000000000001"
                          }
